# ── Telegram credentials ──────────────────────────────────────────────────────
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# ── Optional ──────────────────────────────────────────────────────────────────
# Path to a cookies.txt file (Netscape format) for age-restricted / logged-in content
# Export from your browser using the "Get cookies.txt LOCALLY" extension
YTDLP_COOKIES=

# Directory for temporary download files (default: /tmp/media_saver)
TEMP_DIR=/tmp/media_saver
